#!/usr/bin/env python3
"""Move the mouse a little every 2 minutes to keep the Mac awake."""

import time
import pyautogui

# Fail-safe: slam the cursor into a screen corner to abort the script.
pyautogui.FAILSAFE = True

INTERVAL = 120  # seconds (2 minutes)


def jiggle():
    x, y = pyautogui.position()
    # Nudge right then back so the pointer ends where it started.
    pyautogui.moveTo(x + 1, y, duration=0.2)
    pyautogui.moveTo(x, y, duration=0.2)


def main():
    print(f"Mouse mover running — jiggling every {INTERVAL // 60} min.")
    print("Press Ctrl+C to stop (or fling the cursor to a screen corner).")
    try:
        while True:
            jiggle()
            print(f"Moved at {time.strftime('%H:%M:%S')}")
            time.sleep(INTERVAL)
    except KeyboardInterrupt:
        print("\nStopped.")


if __name__ == "__main__":
    main()
