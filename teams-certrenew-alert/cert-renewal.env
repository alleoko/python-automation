# Microsoft Teams Webhook URL for certificate alerts
# IMPORTANT: Must be wrapped in quotes (") to handle the & characters in the URL
TEAMS_WEBHOOK_URL="https://XXXXXXXX"

# Path where Let's Encrypt certificates are stored (usually /etc/letsencrypt/live)
CERT_PATH=/etc/letsencrypt/live

# Alert threshold in days (certificate will alert if expiring within this many days)
# Default: 7 days
ALERT_DAYS=7
